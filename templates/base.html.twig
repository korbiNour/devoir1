{# templates/project/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Liste des projets{% endblock %}

{% block body %}
<div class="container">
    <h1 class="mb-4">Liste des projets</h1>

    {# Tableau Bootstrap pour afficher les projets #}
    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>Titre</th>
                <th>Enseignant</th>
                <th>Nombre d'étudiants</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for projet in projets %}
                <tr>
                    <td>{{ projet.titre }}</td>
                    <td>{{ projet.enseignant.nom }}</td>
                    <td>{{ projet.etudiants|length }}</td>
                    <td>
                        {% if projet.statut == 'Terminé' %}
                            <span class="badge bg-success">{{ projet.statut }}</span>
                        {% elseif projet.statut == 'En cours' %}
                            <span class="badge bg-warning text-dark">{{ projet.statut }}</span>
                        {% else %}
                            <span class="badge bg-secondary">{{ projet.statut }}</span>
                        {% endif %}
                    </td>
                    <td>
                        <a href="{{ path('project_show', {'id': projet.id}) }}" class="btn btn-info btn-sm">Voir</a>
                        <a href="{{ path('project_edit', {'id': projet.id}) }}" class="btn btn-primary btn-sm">Modifier</a>
                        <a href="{{ path('project_delete', {'id': projet.id}) }}" class="btn btn-danger btn-sm"
                           onclick="return confirm('Voulez-vous vraiment supprimer ce projet ?');">Supprimer</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-center">Aucun projet trouvé.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}